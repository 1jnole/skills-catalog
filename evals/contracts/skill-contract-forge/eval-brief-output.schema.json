{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "skill",
    "authoring",
    "successModel",
    "activationProbes",
    "negativeSignals",
    "sourceRefs"
  ],
  "properties": {
    "skill": {
      "type": "object",
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "authoring": {
      "type": "object",
      "required": [
        "packageShape"
      ],
      "minProperties": 1,
      "anyOf": [
        {
          "required": [
            "singleJob"
          ]
        },
        {
          "required": [
            "job"
          ]
        },
        {
          "required": [
            "primaryJob"
          ]
        },
        {
          "required": [
            "description"
          ]
        },
        {
          "required": [
            "packageShape"
          ]
        }
      ],
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "packageShape": {
                "type": "object",
                "properties": {
                  "supportFolders": {
                    "type": "array",
                    "contains": {
                      "const": "agents"
                    }
                  }
                },
                "required": [
                  "supportFolders"
                ]
              }
            }
          },
          "then": {
            "required": [
              "interface"
            ]
          }
        }
      ],
      "properties": {
        "packageShape": {
          "type": "object",
          "required": [
            "requiredFiles",
            "supportFolders"
          ],
          "properties": {
            "requiredFiles": {
              "type": "array",
              "minItems": 1,
              "contains": {
                "const": "SKILL.md"
              },
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "supportFolders": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "references",
                  "scripts",
                  "assets",
                  "agents"
                ]
              }
            }
          },
          "additionalProperties": true
        },
        "interface": {
          "type": "object",
          "required": [
            "display_name",
            "short_description",
            "default_prompt"
          ],
          "properties": {
            "display_name": {
              "type": "string",
              "minLength": 1
            },
            "short_description": {
              "type": "string",
              "minLength": 1
            },
            "default_prompt": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "successModel": {
      "type": "object",
      "minProperties": 1,
      "anyOf": [
        {
          "required": [
            "outcomeGoals"
          ]
        },
        {
          "required": [
            "mustPass"
          ]
        },
        {
          "required": [
            "criteria"
          ]
        },
        {
          "required": [
            "mustPassChecks"
          ]
        },
        {
          "required": [
            "description"
          ]
        },
        {
          "required": [
            "outcome"
          ]
        }
      ],
      "additionalProperties": true
    },
    "activationProbes": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    },
    "negativeSignals": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    },
    "sourceRefs": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    },
    "seedEvalIntent": {
      "type": "object",
      "properties": {
        "mustStopAt": {
          "type": "string",
          "minLength": 1
        },
        "comparisonFocus": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
