{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "skill",
    "authoring",
    "successModel",
    "activationProbes",
    "negativeSignals",
    "sourceRefs"
  ],
  "properties": {
    "skill": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "authoring": {
      "type": "object",
      "minProperties": 1,
      "anyOf": [
        {
          "required": [
            "singleJob"
          ]
        },
        {
          "required": [
            "job"
          ]
        },
        {
          "required": [
            "primaryJob"
          ]
        },
        {
          "required": [
            "description"
          ]
        }
      ],
      "additionalProperties": true
    },
    "successModel": {
      "type": "object",
      "minProperties": 1,
      "anyOf": [
        {
          "required": [
            "outcomeGoals"
          ]
        },
        {
          "required": [
            "mustPass"
          ]
        },
        {
          "required": [
            "criteria"
          ]
        },
        {
          "required": [
            "mustPassChecks"
          ]
        },
        {
          "required": [
            "description"
          ]
        },
        {
          "required": [
            "outcome"
          ]
        }
      ],
      "additionalProperties": true
    },
    "activationProbes": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    },
    "negativeSignals": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    },
    "sourceRefs": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    },
    "seedEvalIntent": {
      "type": "object",
      "properties": {
        "mustStopAt": {
          "type": "string",
          "minLength": 1
        },
        "comparisonFocus": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
