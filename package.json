{
  "name": "skills-catalog",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@lmnr-ai/lmnr": "^0.8.14",
    "ai": "^6.0.116",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "promptfoo": "^0.120.19",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "promptfoo:validate": "promptfoo validate -c evals/engines/promptfoo/promptfooconfig.mjs",
    "promptfoo:run": "promptfoo eval -c evals/engines/promptfoo/promptfooconfig.mjs -o evals/engines/promptfoo/generated/skill-forge.eval.json --no-progress-bar --table-cell-max-length 80 && node evals/engines/promptfoo/support/benchmark-summary.mjs",
    "promptfoo:run:offline": "promptfoo eval -c evals/engines/promptfoo/promptfooconfig.mjs --model-outputs evals/engines/promptfoo/fixtures/skill-forge-suite-model-outputs.json -o evals/engines/promptfoo/generated/skill-forge.eval.json --no-progress-bar --table-cell-max-length 80 && node evals/engines/promptfoo/support/benchmark-summary.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run"
  }
}
